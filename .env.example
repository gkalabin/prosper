# Public URL the app is reachable at. Used for open banking redirects.
# Use https://example.com in production; http://127.0.0.1:3000 for local dev.
PUBLIC_APP_URL=http://127.0.0.1:3000
# Database connection.
DB_HOST=localhost
DB_PORT=3306
DB_USER=prosper
DB_NAME=prosperdb
DB_PASSWORD=hunter2
# Unix socket for the backend ↔ frontend gRPC channel.
GRPC_SOCKET_PATH=/tmp/prosper.sock
# Background scheduler intervals.
RATE_REFRESH_INTERVAL=6h
# Cap on self-service registrations.
MAX_USERS_ALLOWED_TO_REGISTER=3
# Open banking provider credentials.
TRUE_LAYER_CLIENT_ID=
TRUE_LAYER_CLIENT_SECRET=
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
