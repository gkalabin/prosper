# Public URL the app is reachable at. Used for open banking redirects.
# Use https://example.com in production; http://127.0.0.1:3000 for local dev.
PROSPER_PUBLIC_APP_URL=http://127.0.0.1:3000
# Database connection.
PROSPER_DB_HOST=localhost
PROSPER_DB_PORT=3306
PROSPER_DB_USER=prosper
PROSPER_DB_NAME=prosperdb
PROSPER_DB_PASSWORD=hunter2
# Unix socket for the backend ↔ frontend gRPC channel.
PROSPER_GRPC_SOCKET_PATH=/tmp/prosper.sock
# Background scheduler intervals.
PROSPER_RATE_REFRESH_INTERVAL=6h
# Cap on self-service registrations.
PROSPER_MAX_USERS_ALLOWED_TO_REGISTER=3
# Open banking provider credentials.
PROSPER_TRUE_LAYER_CLIENT_ID=
PROSPER_TRUE_LAYER_CLIENT_SECRET=
PROSPER_GOCARDLESS_SECRET_ID=
PROSPER_GOCARDLESS_SECRET_KEY=
