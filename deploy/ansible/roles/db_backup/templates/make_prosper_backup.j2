#!/bin/bash
# Run an ad-hoc Prosper DB backup: dump the database and push it to the
# backup repo, with an optional note in the commit message.
#
# Usage: make_prosper_backup [note]
set -euo pipefail

exec sudo -u {{ service_user }} {{ bin_dir }}/backup.sh --env-file {{ env_file }} {{ backup_dir }} "$@"
