PROSPER_PUBLIC_APP_URL=https://{{ domain }}
PROSPER_DB_HOST={{ db_host }}
PROSPER_DB_PORT={{ db_port }}
PROSPER_DB_NAME={{ db_name }}
PROSPER_DB_USER={{ db_user }}
PROSPER_DB_PASSWORD={{ db_password }}
PROSPER_GRPC_SOCKET_PATH={{ grpc_socket_path }}
PROSPER_MAX_USERS_ALLOWED_TO_REGISTER={{ max_users_allowed_to_register }}
{% if true_layer_client_id %}
PROSPER_TRUE_LAYER_CLIENT_ID={{ true_layer_client_id }}
PROSPER_TRUE_LAYER_CLIENT_SECRET={{ true_layer_client_secret }}
{% endif %}
{% if gocardless_secret_id %}
PROSPER_GOCARDLESS_SECRET_ID={{ gocardless_secret_id }}
PROSPER_GOCARDLESS_SECRET_KEY={{ gocardless_secret_key }}
{% endif %}
