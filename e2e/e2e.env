PROSPER_DB_HOST=127.0.0.1
PROSPER_DB_PORT=3307
PROSPER_DB_USER=root
PROSPER_DB_PASSWORD=root
PROSPER_DB_NAME=prosper_e2e_test_db
PORT=3003
PROSPER_PUBLIC_APP_URL=http://127.0.0.1:3003
PROSPER_MAX_USERS_ALLOWED_TO_REGISTER=1000
PROSPER_GRPC_SOCKET_PATH=/tmp/prosper.sock
# Disable the background fetch schedulers so e2e runs make no external
# HTTP calls (Yahoo Finance, open banking providers).
PROSPER_RATE_REFRESH_INTERVAL=0
